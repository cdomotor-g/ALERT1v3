[Unit]
Description=FW-LAB Receiver (GNU Radio)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=cdomotor
Group=cdomotor
WorkingDirectory=/home/cdomotor/.openclaw/workspace/projects/ALERT1v3
ExecStart=/home/cdomotor/.openclaw/workspace/projects/ALERT1v3/tools/start_receiver.sh
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1
Environment=QT_QPA_PLATFORM=offscreen

[Install]
WantedBy=multi-user.target
